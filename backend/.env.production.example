# Django Settings
DJANGO_SECRET_KEY=generate-a-long-random-string-here-min-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=readex-api.onrender.com,your-domain.com
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# CORS & CSRF
CORS_ALLOWED_ORIGINS=https://readex-frontend.netlify.app,https://your-custom-domain.com
CSRF_TRUSTED_ORIGINS=https://readex-frontend.netlify.app,https://your-custom-domain.com

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# JWT & Cookies
JWT_COOKIE_SECURE=True
JWT_COOKIE_SAMESITE=None
JWT_COOKIE_HTTP_ONLY=True

# Frontend URLs
FRONTEND_URL=https://readex-frontend.netlify.app

# Payment Gateway (if using Chargily)
CHARGILY_SECRET_KEY=your-chargily-secret-key-here

# Optional: Email settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
